@startuml
title casbinjs/react - Component View and Responsibility Boundaries

skinparam componentStyle rectangle
skinparam shadowing false

actor ReactConsumer as Consumer

package "Consumer App" {
  component "App-owned Data Fetching" as Fetching
  component "UI Components" as UI
}

package "casbinjs/react" {
  interface "useAuthz()" as UseAuthz
  interface "usePermissionsEnforcer()" as UsePermissionsEnforcer
  component "AuthzProvider" as Provider
  component "React Context" as Context
  component "React Helpers" as Helpers
}

package "casbinjs/core" {
  interface "Authorizer" as Authorizer
}

database "External Endpoint / Data Source" as Endpoint

Consumer <-- UI
Endpoint ---> Fetching : AuthorizationPayload

Fetching --> Provider : pass authorizer or payload
Provider -> Context : provide authz state
Provider ---> Authorizer : create / use authorizer
Helpers --> UseAuthz
Helpers --> UsePermissionsEnforcer
UseAuthz <-- Context : consume authorizer state
UsePermissionsEnforcer --> UseAuthz : build convenience helpers
UI <-- UseAuthz : can / canAny / canAll
UI <-- UsePermissionsEnforcer : canView / canUpdate / etc.

note top of Fetching
Application-owned fetching.
Not part of casbinjs/react.
end note

note bottom of Provider
casbinjs/react owns:
- provider wiring
- context integration
- React-ready hooks
- convenience helpers
end note

note top of Authorizer
casbinjs/core owns:
- vanilla-ready authorizer contract
- delegation to casbin-core
end note
@enduml
