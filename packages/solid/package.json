{
  "name": "@casbinjs/solid",
  "version": "0.0.1",
  "description": "CasbinJS Solid bindings",
  "repository": {
    "type": "git",
    "url": "https://github.com/proveo-ca/casbinjs.git",
    "directory": "packages/solid"
  },
  "homepage": "https://github.com/proveo-ca/casbinjs/tree/main/packages/solid",
  "bugs": "https://github.com/proveo-ca/casbinjs/issues",
  "license": "ISC",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist", "README.md"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist node_modules"
  },
  "peerDependencies": {
    "solid-js": ">=1.6.0"
  },
  "devDependencies": {
    "@solidjs/testing-library": "^0.8.10",
    "jsdom": "^29.0.0",
    "rimraf": "^5.0.5",
    "solid-js": "^1.9.7",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vite-plugin-solid": "^2.11.6",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "@casbinjs/core": "workspace:*"
  }
}
