{
  "name": "@casbinjs/react",
  "version": "0.0.1",
  "description": "CasbinJS React bindings",
  "repository": {
    "type": "git",
    "url": "https://github.com/proveo-ca/casbinjs.git",
    "directory": "packages/react"
  },
  "homepage": "https://github.com/proveo-ca/casbinjs/tree/main/packages/react",
  "bugs": "https://github.com/proveo-ca/casbinjs/issues",
  "license": "ISC",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist", "README.md"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist node_modules"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "jsdom": "^29.0.0",
    "rimraf": "^5.0.5",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "dependencies": {
    "@casbinjs/core": "workspace:*"
  }
}
