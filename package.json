{
  "name": "casbinjs",
  "private": true,
  "packageManager": "pnpm@10.30.0",
  "scripts": {
    "build": "pnpx turbo run build",
    "clean": "pnpx turbo run clean && rimraf node_modules",
    "dev": "pnpx turbo run dev --parallel",
    "test": "pnpx turbo run test",
    "test:watch": "pnpx turbo run test:watch --parallel",
    "typecheck": "pnpx turbo run typecheck",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "format": "oxfmt .",
    "format:check": "oxfmt . --check",
    "check": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@typescript/native-preview": "7.0.0-dev.20260316.1",
    "oxfmt": "^0.15.0",
    "oxlint": "^0.15.0",
    "rimraf": "^5.0.5",
    "tsup": "^8.5.1",
    "turbo": "^2.0.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "casbin-core"
    ]
  }
}
